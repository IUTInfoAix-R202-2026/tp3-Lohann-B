<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.BorderPane?>

<!--
  Vue d'exemple pour l'exercice 1 : BorderPane avec padding, titre, texte
  explicatif et bouton en bas. Vue statique, pas de controller.
-->

<BorderPane xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1"
  prefWidth="420.0" prefHeight="240.0">

  <padding>
    <Insets top="20.0" right="20.0" bottom="20.0" left="20.0" />
  </padding>

  <top>
    <Label text="Bienvenue dans le monde FXML !"
      style="-fx-font-weight: bold; -fx-font-size: 20px;"
      BorderPane.alignment="CENTER" />
  </top>

  <center>
    <Label
      text="Ceci est une vue statique écrite en FXML. Tu peux modifier ce texte librement pour expliquer l'interface."
      wrapText="true"
      BorderPane.alignment="CENTER" />
  </center>

  <bottom>
    <Button text="D'accord, c'est magique" BorderPane.alignment="CENTER" />
  </bottom>

</BorderPane>